Algoritmo "atividade_18"

Var
usuario:caracter
senha:inteiro


Inicio
escreval("escreva o seu usuario")
 leia(usuario)
escreva("escreva a sua senha")
leia(senha)
se (usuario="adimin") e (senha=1234) entao
	escreval("acesso permitido")
senao
	escreval("acesso negado")
fimse


Fimalgoritmo