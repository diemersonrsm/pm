Algoritmo "atividade_23"

Var
n1 ,n2 ,n3 ,n4 ,n5, media:real
Inicio
escreva("primeiro numero:")
leia(n1)
escreva("segundo numero:")
leia(n2)
escreva("terceiro numero:")
leia(n3)
escreva("quarto numero:")
leia(n4)
escreva("quinto numero:")
leia(n5)
media <- (n1+n2+n3+n4+n5)/5
escreva("a media destes valores é:",media)
Fimalgoritmo







