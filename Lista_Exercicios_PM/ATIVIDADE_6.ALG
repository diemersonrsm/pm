Algoritmo "atividade_6"

Var
numero1:inteiro
numero2:inteiro
numero3:inteiro
media:real
Inicio
 escreva("coloque o primeiro numero:")
 leia(numero1)
escreva("coloque o segundo numero:")
leia(numero2)
escreva("coloque o terceiro numero:")
leia(numero3)
media <- ((numero1+numero2+numero3)/3)
escreva("a media e igual a",media)
Fimalgoritmo