Algoritmo "Atividade_25"

Var

  n,maior,menor:real
  i:inteiro

Inicio
  para i de 1 ate 10 faca
  escreval("coloque o seu numero aqui:")
  leia(n)
 se (n > maior) entao
        maior <- maior * 0 + n
     senao
          menor <- menor * 0 + n
     fimse
     fimpara
 escreva("o numkero maior  e:",maior)
 escreval(" o numero menor e:", maior)
Fimalgoritmo