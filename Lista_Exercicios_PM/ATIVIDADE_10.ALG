Algoritmo "atividade_10"

Var
num1:inteiro
num2:inteiro
resultado:real
Inicio
escreva("coloque o primeiro numero:")
leia(num1)
escreva("coloque o segundo numero:")
leia(num2)
resultado <- (num1 - num2 )
se resultado>0 entao
   escreva(num1," e o maior ")
senao
     escreva(num2, " e o maior numero")

fimse
Fimalgoritmo
