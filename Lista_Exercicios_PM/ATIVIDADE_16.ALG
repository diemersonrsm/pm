Algoritmo "atividade_16"

Var
 lado1:inteiro
 lado2:inteiro
 lado3:inteiro


Inicio
escreva("coloque o primeiro lado:")
   leia(lado1)
escreva("coloque o segundo lado:")
   leia(lado2)
escreva("coloque o terceiro lado:")
   leia(lado3)
se (lado1+lado2>lado3) entao
   escreva("e um trinagulo")
senao
     escreval("năo e um trinagulo")
     fimse
Fimalgoritmo